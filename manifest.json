{
  "version": "1.0",
  "name": "Youtube Comments Sidebar",
  "description": "Instantly view YouTube comments right next to your video - no scrolling needed.",
  "icons": {
    "128": "youtubeIcon.png"
  },
  "action": {
    "default_icon": "youtubeIcon.png"
  },
  "content_scripts": [
    {
      "js": [
        "content.js"
      ],
      "matches": [
        "https://www.youtube.com/*"
      ],
      "css": [
        "styles.css"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "buttonIcon.png"
      ],
      "matches": [
        "https://www.youtube.com/*"
      ]
    }
  ],
  "manifest_version": 3
}